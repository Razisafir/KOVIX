# ═══════════════════════════════════════════════════════════════════════════════
# Construct AI Agent — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Frontend URLs ────────────────────────────────────────────────────────────
# In development:
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# In production (uncomment and set your backend URL):
# VITE_API_URL=https://your-backend-url.com
# VITE_WS_URL=wss://your-backend-url.com

# ─── LLM API Keys (optional — local LLM works without any keys) ───────────────
# OpenAI — GPT-4o, GPT-4o-mini (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic — Claude 3.5 Sonnet, Claude 3 Opus (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google — Gemini 1.5 Pro (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your-google-key-here

# ─── Local LLM (free, completely offline) ─────────────────────────────────────
# Install Ollama: https://ollama.ai
# Then run: ollama pull llama3.1
OLLAMA_HOST=http://localhost:11434

# ─── Backend Settings ─────────────────────────────────────────────────────────
# Where Construct stores its memory (SQLite + ChromaDB)
DATABASE_URL=sqlite:///app/data/construct.db
CHROMA_PERSIST_DIR=./resources/vector
SKILLS_DIR=./resources/skills

# Security (generate a strong secret: openssl rand -hex 32)
SECRET_KEY=construct-dev-secret-change-in-production
ALLOWED_ORIGINS=*

# Feature toggles
MAX_CONCURRENT_AGENTS=5
CONTEXT_LIMIT=200000
AUTONOMOUS_ENABLED=true

# Logging
LOG_LEVEL=DEBUG
