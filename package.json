{
  "name": "construct",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "cd src/main && tauri dev",
    "tauri:build": "cd src/main && tauri build",
    "build:mac": "cd src/main && tauri build --target universal-apple-darwin",
    "build:win": "cd src/main && tauri build --target x86_64-pc-windows-msvc",
    "build:linux": "cd src/main && tauri build --target x86_64-unknown-linux-gnu",
    "build:all": "npm run build:mac && npm run build:win && npm run build:linux",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "prebuild": "tsc --noEmit",
    "lint": "tsc --noEmit && echo 'Type check passed'",
    "build:web": "vite build --mode web",
    "preview:web": "vite preview --mode web",
    "docker:build": "docker build -t construct .",
    "docker:up": "docker compose up --build",
    "docker:backend": "docker compose --profile backend up --build",
    "icons:generate": "cd src/main && cargo tauri icon ../../icons/icon.png"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "allotment": "^1.20.5",
    "lucide-react": "^0.460.0",
    "monaco-editor": "^0.52.0",
    "react": "^18.3.1",
    "react-complex-tree": "^2.6.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.13.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^2.1.8"
  }
}
