{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"noUnusedLocals": false,
		"noImplicitReturns": false,
		"skipLibCheck": true,
		"outDir": "../out/vs"
	},
	"include": [
		"./vs/platform/construct/common/mcp/**/*.ts",
